# VieForce HQ API — environment template
# Copy to .env.local and fill in real values (.env.local is gitignored).
# Production values live on Cloud Run env vars; never commit real secrets.

# ── SAP B1 ───────────────────────────────────────────────────────────────
SAP_HOST=analytics.vienovo.ph
SAP_PORT=4444
SAP_DB=Vienovo_Live
SAP_DB_HISTORICAL=Vienovo_Old
SAP_MIGRATION_CUTOFF=2026-01-01
SAP_USER=gsheet
SAP_PASS=

# ── Supabase (shared users table + silence feature) ──────────────────────
SUPABASE_URL=https://yolxcmeoovztuindrglk.supabase.co
SUPABASE_ANON_KEY=
# SERVICE_ROLE key: REQUIRED for /api/admin/* (auth.admin.* writes bypass RLS).
# Also used by /api/_scope for manager_id chain resolution (falls back to ANON
# for scope reads only; admin writes will 503 without this key).
# Get it from: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── Service-to-service auth (Patrol ↔ HQ) ────────────────────────────────
# Shared secret for Bearer-token auth on /api/* routes that need S2S access.
# Generate: openssl rand -base64 32
# Store in 1Password; set on Cloud Run via `gcloud run services update --update-env-vars`
# NEVER commit the real token.
HQ_SERVICE_TOKEN=

# ── Misc ─────────────────────────────────────────────────────────────────
TARGET_MT=188266
